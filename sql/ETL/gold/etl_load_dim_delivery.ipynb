   "source": [
    "%sql\n",
    "MERGE INTO catalog_ventas.gold.dim_delivery AS tgt\n",
    "USING (\n",
    "  SELECT DISTINCT delivery\n",
    "  FROM catalog_ventas.silver.ventas_clean\n",
    "  WHERE delivery IS NOT NULL \n",
    ") AS src\n",
    "ON tgt.delivery = src.delivery\n",
    "\n",
    "WHEN NOT MATCHED THEN\n",
    "  INSERT (delivery)\n",
    "  VALUES (src.delivery);"
   ]
  }
 ],
